---
const navLinks = [
  { label: 'Talks', href: '/talks' },
  { label: 'About', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header style="border-bottom: 1px solid var(--color-border);">
  <div class="mx-auto flex items-center justify-between px-6 py-4" style="max-width: 48rem;">
    <a href="/" class="text-base font-bold" style="color: var(--color-text-primary);">
      naokihaba blog
    </a>
    <nav class="flex items-center gap-6">
      {navLinks.map((link) => {
        const isActive = currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href));
        return (
          <a
            href={link.href}
            class="text-sm"
            style={isActive ? 'color: var(--color-text-primary); font-weight: 600;' : 'color: var(--color-text-secondary);'}
          >
            {link.label}
          </a>
        );
      })}
      <a href="https://github.com/naokihaba" target="_blank" rel="noopener noreferrer" class="text-sm" style="color: var(--color-text-secondary);">GitHub</a>
      <a href="/rss.xml" class="text-sm" style="color: var(--color-text-secondary);">RSS</a>
    </nav>
  </div>
</header>
