---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allTalks = await getCollection('talks');

const sortedTalks = allTalks.sort((a, b) =>
  b.data.date.getTime() - a.data.date.getTime()
);

const talksByYear = sortedTalks.reduce((acc, talk) => {
  const year = talk.data.date.getFullYear();
  if (!acc[year]) acc[year] = [];
  acc[year].push(talk);
  return acc;
}, {} as Record<number, typeof sortedTalks>);

const years = Object.keys(talksByYear).map(Number).sort((a, b) => b - a);
---

<Layout title="Talks" description="登壇資料やプレゼンテーションのまとめ">
  <div class="mx-auto px-6 py-12" style="max-width: 48rem;">
    {sortedTalks.length > 0 ? (
      years.map((year) => (
        <section class="mb-12">
          <h2 class="mb-4 text-sm font-semibold" style="color: var(--color-text-secondary);">{year}</h2>
          <ul class="list-none space-y-8 p-0">
            {talksByYear[year].map((talk) => (
              <li>
                {talk.data.slidesEmbedUrl && (
                  <div class="mb-3 w-full overflow-hidden rounded-lg" style="aspect-ratio: 16/9;">
                    <iframe
                      src={talk.data.slidesEmbedUrl}
                      class="size-full"
                      allowfullscreen
                      loading="lazy"
                      style="border: 0;"
                    ></iframe>
                  </div>
                )}
                <div class="flex items-baseline justify-between gap-4">
                  <div>
                    <p class="text-base font-medium" style="color: var(--color-text-primary);">{talk.data.title}</p>
                    {talk.data.event && (
                      <p class="text-sm mt-0.5" style="color: var(--color-text-secondary);">{talk.data.event}</p>
                    )}
                    <div class="flex gap-3 mt-1 text-sm">
                      {talk.data.slidesUrl && (
                        <a href={talk.data.slidesUrl} target="_blank" rel="noopener noreferrer" style="color: var(--color-primary);">Slides</a>
                      )}
                      {talk.data.videoUrl && (
                        <a href={talk.data.videoUrl} target="_blank" rel="noopener noreferrer" style="color: var(--color-primary);">Video</a>
                      )}
                    </div>
                  </div>
                  <time class="shrink-0 text-sm tabular-nums" style="color: var(--color-text-secondary);" datetime={talk.data.date.toISOString()}>
                    {talk.data.date.toLocaleDateString('ja-JP', { month: '2-digit', day: '2-digit' })}
                  </time>
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))
    ) : (
      <p class="text-sm" style="color: var(--color-text-secondary);">No talks yet.</p>
    )}
  </div>
</Layout>
